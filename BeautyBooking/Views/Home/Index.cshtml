@using System.Globalization
@using BeautyBooking.Localization
@{
    Layout = null;
    var currentLanguage = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    Func<string, string> T = key => SiteText.Get(key, currentLanguage);
}
<!doctype html>
<html class="no-js" lang="@currentLanguage">
<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>@T("MetaTitle")</title>
    <meta name="description" content="@T("MetaDescription")">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="canonical" href="https://www.anova.dk/">

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/vendor.css">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/pages.css">
    <link rel="stylesheet" href="/css/onepage-redesign.css?v=20260618-9">

    <script src="/js/vendor/modernizr-2.8.3.min.js"></script>
</head>
<body class="onepage-home">
    <header class="site-nav-wrap">
        <nav class="navbar navbar-default site-nav" id="top-nav">
            <div class="container">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar" aria-expanded="false">
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>
                    <a class="navbar-brand" href="#hero">
                        <img alt="Anova logo" src="/img/logo-gold.png">
                    </a>
                </div>

                <div class="collapse navbar-collapse navbar-right" id="navbar">
                    <ul class="nav navbar-nav">
                        <li><a href="#hero">@T("NavHome")</a></li>
                        <li><a href="#about">@T("NavAbout")</a></li>
                        <li><a href="#services">@T("NavServices")</a></li>
                        <li><a href="#gallery">@T("NavGallery")</a></li>
                        <li><a href="#hours-contact">@T("NavContact")</a></li>
                        <li class="nav-cta"><a href="/book">@T("NavBook")</a></li>
                        <li class="language-switcher"><a href="/home?culture=da&ui-culture=da">DA</a></li>
                        <li class="language-switcher"><a href="/home?culture=en&ui-culture=en">EN</a></li>
                        <li class="language-switcher"><a href="/home?culture=fr&ui-culture=fr">FR</a></li>
                        <li class="language-switcher"><a href="/home?culture=de&ui-culture=de">DE</a></li>
                        <li class="language-switcher"><a href="/home?culture=zh&ui-culture=zh">中文</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <section id="hero" class="hero-premium">
            <div class="hero-backdrop"></div>
            <div class="container">
                <div class="hero-content">
                    <p class="eyebrow hero-brand">@T("HeroBrand")</p>
                    <h1>@T("HeroTitle")</h1>
                    <p>@T("HeroLead")</p>
                    <div class="hero-actions">
                        <a href="/book" class="btn btn-default btn-gold">@T("HeroBook")</a>
                        <a href="#services" class="btn btn-bordered btn-light">@T("HeroViewServices")</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="about" class="section-block about-block">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <img src="/img/gallery/gallery1.png" class="feature-image" alt="Salon interior">
                    </div>
                    <div class="col-md-6">
                        <p class="eyebrow">@T("AboutEyebrow")</p>
                        <h2>@T("AboutTitle")</h2>
                        <p>@T("AboutText1")</p>
                        <p>@T("AboutText2")</p>
                        <a href="/book" class="btn btn-default btn-gold">@T("AboutBook")</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="services" class="section-block services-block">
            <div class="container">
                <div class="section-headline-modern">
                    <p class="eyebrow">@T("ServicesEyebrow")</p>
                    <h2>@T("ServicesTitle")</h2>
                </div>
                <div class="service-grid">
                    <article class="service-card">
                        <h3>@T("Service1Name")</h3>
                        <p>@T("Service1Text")</p>
                        <div class="meta"><span>@T("Service1Meta")</span><strong>@T("Service1Price")</strong></div>
                        <a href="/book">@T("BookOnline")</a>
                    </article>
                    <article class="service-card">
                        <h3>@T("Service2Name")</h3>
                        <p>@T("Service2Text")</p>
                        <div class="meta"><span>@T("Service2Meta")</span><strong>@T("Service2Price")</strong></div>
                        <a href="/book">@T("BookOnline")</a>
                    </article>
                    <article class="service-card">
                        <h3>@T("Service3Name")</h3>
                        <p>@T("Service3Text")</p>
                        <div class="meta"><span>@T("Service3Meta")</span><strong>@T("Service3Price")</strong></div>
                        <a href="/book">@T("BookOnline")</a>
                    </article>
                    <article class="service-card">
                        <h3>@T("Service4Name")</h3>
                        <p>@T("Service4Text")</p>
                        <div class="meta"><span>@T("Service4Meta")</span><strong>@T("Service4Price")</strong></div>
                        <a href="/book">@T("BookOnline")</a>
                    </article>
                </div>
            </div>
        </section>

        <section id="gallery" class="section-block gallery-block">
            <div class="container">
                <div class="section-headline-modern">
                    <p class="eyebrow">@T("GalleryEyebrow")</p>
                    <h2>@T("GalleryTitle")</h2>
                </div>
                <div class="gallery-grid">
                    <img src="/img/home/gallery1.png" alt="Hair style example 1">
                    <img src="/img/home/gallery2.png" alt="Hair style example 2">
                    <img src="/img/home/gallery3.png" alt="Hair style example 3">
                    <img src="/img/home/gallery4.png" alt="Hair style example 4">
                </div>
            </div>
        </section>

        <section id="hours-contact" class="section-block contact-hours-block">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <p class="eyebrow">@T("HoursEyebrow")</p>
                        <h2>@T("HoursTitle")</h2>
                        <ul class="hours-list">
                            <li><span>@T("Mon")</span><strong>09:00 - 18:00</strong></li>
                            <li><span>@T("Tue")</span><strong>09:00 - 18:00</strong></li>
                            <li><span>@T("Wed")</span><strong>09:00 - 18:00</strong></li>
                            <li><span>@T("Thu")</span><strong>09:00 - 18:00</strong></li>
                            <li><span>@T("Fri")</span><strong>09:00 - 18:00</strong></li>
                            <li><span>@T("Sat")</span><strong>09:00 - 17:00</strong></li>
                            <li><span>@T("Sun")</span><strong>@T("Closed")</strong></li>
                        </ul>
                    </div>
                    <div class="col-md-6 contact-info-card">
                        <p class="eyebrow">@T("ContactEyebrow")</p>
                        <h3>@T("ContactName")</h3>
                        <p>@T("ContactAddress")</p>
                        <p><a href="tel:+4541423333">+45 41 42 33 33</a></p>
                        <p>
                            <a class="social-link" href="https://www.instagram.com/salon_anova_?igsh=a3ZrMGF1YWxicnMy" target="_blank" rel="noopener">
                                <i class="fa fa-instagram" aria-hidden="true"></i>
                                <span>@T("Instagram")</span>
                            </a>
                        </p>
                        <a class="btn btn-default btn-dark" href="https://maps.google.com/?q=Amagerbrogade+219,+2300+Kobenhavn+S" target="_blank" rel="noopener">@T("FindWay")</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="booking" class="section-block booking-strip">
            <div class="container">
                <div class="booking-panel">
                    <h2>@T("BookingTitle")</h2>
                    <p>@T("BookingText")</p>
                    <a href="/book" class="btn btn-default btn-gold">@T("BookingCta")</a>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <img src="/img/logo-gold.png" alt="Anova logo" class="footer-logo">
                    <p>@T("FooterTagline")</p>
                </div>
                <div>
                    <h4>@T("FooterQuickLinks")</h4>
                    <ul>
                        <li><a href="#hero">@T("NavHome")</a></li>
                        <li><a href="#about">@T("NavAbout")</a></li>
                        <li><a href="#services">@T("NavServices")</a></li>
                        <li><a href="#hours-contact">@T("NavContact")</a></li>
                    </ul>
                </div>
                <div>
                    <h4>@T("FooterBook")</h4>
                    <p>@T("FooterBookText")</p>
                    <a href="/book" class="footer-book-link">@T("FooterGoBooking")</a>
                </div>
            </div>
            <p class="copyright">@T("FooterCopyright")</p>
        </div>
    </footer>

    <script src="/js/vendor/jquery-1.12.4.min.js"></script>
    <script src="/js/vendor/bootstrap.min.js"></script>
    <script src="/js/vendor/owl.carousel.min.js"></script>
    <script src="/js/vendor/jquery.magnific-popup.min.js"></script>
    <script src="/js/vendor/circle-progress.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>