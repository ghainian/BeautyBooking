@{
    Layout = null;
}
<!doctype html>
<html class="no-js" lang="da">
<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>Anova Salon | Frisor i Kobenhavn</title>
    <meta name="description" content="Anova Salon pa Amagerbrogade i Kobenhavn tilbyder professionel dameklip, herreklip og borneklip. Book tid online i dag.">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="canonical" href="https://www.anova.dk/">

    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/vendor.css">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/pages.css">
    <link rel="stylesheet" href="/css/onepage-redesign.css?v=20260618-7">

    <script src="/js/vendor/modernizr-2.8.3.min.js"></script>
</head>
<body class="onepage-home">
    <header class="site-nav-wrap">
        <nav class="navbar navbar-default site-nav" id="top-nav">
            <div class="container">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar" aria-expanded="false">
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>
                    <a class="navbar-brand" href="#hero">
                        <img alt="Anova logo" src="/img/logo-gold.png">
                    </a>
                </div>

                <div class="collapse navbar-collapse navbar-right" id="navbar">
                    <ul class="nav navbar-nav">
                        <li><a href="#hero">Home</a></li>
                        <li><a href="#about">Om Os</a></li>
                        <li><a href="#services">Services</a></li>
                        <li><a href="#gallery">Galleri</a></li>
                        <li><a href="#hours-contact">Kontakt</a></li>
                        <li class="nav-cta"><a href="/book">Bestil Online</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <section id="hero" class="hero-premium">
            <div class="hero-backdrop"></div>
            <div class="container">
                <div class="hero-content">
                    <p class="eyebrow hero-brand">SALON ANOVA</p>
                    <h1>Eksklusiv haircare med fokus pa detaljer</h1>
                    <p>
                        Step ind i et roligt rum for moderne klip, styling og personlig service.
                        Vi kombinerer klassisk handvaerk med nutidigt look i hjertet af Amager.
                    </p>
                    <div class="hero-actions">
                        <a href="/book" class="btn btn-default btn-gold">Bestil tid</a>
                        <a href="#services" class="btn btn-bordered btn-light">Se services</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="about" class="section-block about-block">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <img src="/img/gallery/gallery1.png" class="feature-image" alt="Salon interior">
                    </div>
                    <div class="col-md-6">
                        <p class="eyebrow">About us</p>
                        <h2>Passion for detail i hver behandling</h2>
                        <p>
                            Velkommen til Anova, Salon din nye hardestination i Kobenhavn.
                            Uanset om du er mand, kvinde, barn eller senior, tilpasser vi hver behandling
                            til dit behov og din stil.
                        </p>
                        <p>
                            Vores erfarne stylister arbejder med produkter af hoj kvalitet i afslappede
                            omgivelser, sa du gar herfra med et look der holder.
                        </p>
                        <a href="/book" class="btn btn-default btn-gold">Book appointment</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="services" class="section-block services-block">
            <div class="container">
                <div class="section-headline-modern">
                    <p class="eyebrow">Our services</p>
                    <h2>Populaere behandlinger</h2>
                </div>
                <div class="service-grid">
                    <article class="service-card">
                        <h3>Herreklip</h3>
                        <p>Klassisk eller moderne herreklip med professionel finish.</p>
                        <div class="meta"><span>30 min</span><strong>369 DKK</strong></div>
                        <a href="/book">Bestil Online</a>
                    </article>
                    <article class="service-card">
                        <h3>Dameklip</h3>
                        <p>Skraddersyet dameklip med fokus pa form, volumen og stil.</p>
                        <div class="meta"><span>45 min</span><strong>fra 459 DKK</strong></div>
                        <a href="/book">Bestil Online</a>
                    </article>
                    <article class="service-card">
                        <h3>Born under 12</h3>
                        <p>Tryg og rolig klipning med tid til de mindste kunder.</p>
                        <div class="meta"><span>25 min</span><strong>239 DKK</strong></div>
                        <a href="/book">Bestil Online</a>
                    </article>
                    <article class="service-card">
                        <h3>Styling</h3>
                        <p>Styling til event, hverdag eller et hurtigt polish af dit look.</p>
                        <div class="meta"><span>30 min</span><strong>fra 299 DKK</strong></div>
                        <a href="/book">Bestil Online</a>
                    </article>
                </div>
            </div>
        </section>

        <section id="gallery" class="section-block gallery-block">
            <div class="container">
                <div class="section-headline-modern">
                    <p class="eyebrow">Gallery</p>
                    <h2>Udvalgte resultater</h2>
                </div>
                <div class="gallery-grid">
                    <img src="/img/home/gallery1.png" alt="Hair style example 1">
                    <img src="/img/home/gallery2.png" alt="Hair style example 2">
                    <img src="/img/home/gallery3.png" alt="Hair style example 3">
                    <img src="/img/home/gallery4.png" alt="Hair style example 4">
                </div>
            </div>
        </section>

        <section id="hours-contact" class="section-block contact-hours-block">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <p class="eyebrow">Opening hours</p>
                        <h2>Vi har abent naesten hele ugen</h2>
                        <ul class="hours-list">
                            <li><span>Mandag</span><strong>09:00 - 18:00</strong></li>
                            <li><span>Tirsdag</span><strong>09:00 - 18:00</strong></li>
                            <li><span>Onsdag</span><strong>09:00 - 18:00</strong></li>
                            <li><span>Torsdag</span><strong>09:00 - 18:00</strong></li>
                            <li><span>Fredag</span><strong>09:00 - 18:00</strong></li>
                            <li><span>Lordag</span><strong>09:00 - 17:00</strong></li>
                            <li><span>Sondag</span><strong>Lukket</strong></li>
                        </ul>
                    </div>
                    <div class="col-md-6 contact-info-card">
                        <p class="eyebrow">Contact</p>
                        <h3>Salon Anova</h3>
                        <p>Amagerbrogade 219, 2300 Kobenhavn S</p>
                        <p><a href="tel:+4541423333">+45 41 42 33 33</a></p>
                        <p>
                            <a class="social-link" href="https://www.instagram.com/salon_anova_?igsh=a3ZrMGF1YWxicnMy" target="_blank" rel="noopener">
                                <i class="fa fa-instagram" aria-hidden="true"></i>
                                <span>Instagram</span>
                            </a>
                        </p>
                        <a class="btn btn-default btn-dark" href="https://maps.google.com/?q=Amagerbrogade+219,+2300+Kobenhavn+S" target="_blank" rel="noopener">Find vej</a>
                    </div>
                </div>
            </div>
        </section>

        <section id="booking" class="section-block booking-strip">
            <div class="container">
                <div class="booking-panel">
                    <h2>Klar til et nyt look?</h2>
                    <p>Book din tid online pa under et minut.</p>
                    <a href="/book" class="btn btn-default btn-gold">Bestil Online</a>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <img src="/img/logo-gold.png" alt="Anova logo" class="footer-logo">
                    <p>Eksklusiv craftsmanship og wellness i hjertet af Amager.</p>
                </div>
                <div>
                    <h4>Quick links</h4>
                    <ul>
                        <li><a href="#hero">Home</a></li>
                        <li><a href="#about">Om Os</a></li>
                        <li><a href="#services">Services</a></li>
                        <li><a href="#hours-contact">Kontakt</a></li>
                    </ul>
                </div>
                <div>
                    <h4>Book</h4>
                    <p>Book direkte pa vores interne bookingside.</p>
                    <a href="/book" class="footer-book-link">Ga til booking</a>
                </div>
            </div>
            <p class="copyright">© 2026 Anova Salon. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/vendor/jquery-1.12.4.min.js"></script>
    <script src="/js/vendor/bootstrap.min.js"></script>
    <script src="/js/vendor/owl.carousel.min.js"></script>
    <script src="/js/vendor/jquery.magnific-popup.min.js"></script>
    <script src="/js/vendor/circle-progress.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>